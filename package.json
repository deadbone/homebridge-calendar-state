{
  "name": "homebridge-calendar-state",
  "displayName": "Homebridge Calendar State",
  "version": "0.1.2",
  "description": "Configurable calendar state sensors for Homebridge and HomeKit.",
  "license": "MIT",
  "author": "Thierry Lubrez",
  "homepage": "https://github.com/deadbone/homebridge-calendar-state#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deadbone/homebridge-calendar-state.git"
  },
  "bugs": {
    "url": "https://github.com/deadbone/homebridge-calendar-state/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "calendar",
    "homekit",
    "automation"
  ],
  "engines": {
    "homebridge": "^1.8.0 || ^2.0.0",
    "node": "^22.12.0 || ^24.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "config.schema.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "format": "prettier --write \"{src,test}/**/*.ts\" \"*.md\" \"wiki/**/*.md\"",
    "lint": "eslint src test --ext .ts",
    "prepack": "npm run build",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.14",
    "eslint": "^9.31.0",
    "homebridge": "^2.1.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0"
  }
}
